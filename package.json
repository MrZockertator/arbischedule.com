{
  "name": "arbischedule",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node scripts/prepare-html-template.mjs",
    "preview": "vite preview",
    "verify:deploy": "node scripts/verify-deploy.mjs",
    "lint": "eslint . --max-warnings=0",
    "lint:css": "stylelint \"src/styles/**/*.css\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run lint:css && npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^24.5.2",
    "eslint": "^9.24.0",
    "globals": "^17.4.0",
    "html2canvas": "^1.4.1",
    "jsdom": "^24.1.3",
    "stylelint": "^16.24.0",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.43.0",
    "vite": "^7.1.5",
    "vitest": "^4.0.18"
  }
}
